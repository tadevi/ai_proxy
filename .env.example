DATABASE_URL=postgresql://gateway:gateway@localhost:5432/gateway
# CA used to validate the PostgreSQL server TLS certificate. Use an absolute path in production.
# DATABASE_SSL_CA_PATH=./ca.pem
# Required only when PostgreSQL uses mutual TLS/client-certificate authentication.
# DATABASE_SSL_CERT_PATH=./client-cert.pem
# DATABASE_SSL_KEY_PATH=./client-key.pem
SESSION_SECRET=replace-with-at-least-32-random-bytes
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-random-bytes-as-base64
PUBLIC_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
ALLOW_PRIVATE_UPSTREAMS=true
UPSTREAM_TIMEOUT_MS=60000
# Request metadata and sanitized provider errors older than this are removed automatically.
LOG_RETENTION_DAYS=7
